<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="5dp"
    app:cardBackgroundColor="@color/dn_bookcity_host_item_background"
    android:layout_marginTop="5dp"
    android:layout_marginEnd="5dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvHost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:maxLines="1"
            android:text="Host"
            android:textColor="@color/dn_text_color_black"
            android:textSize="14dp"
            app:layout_constraintEnd_toStartOf="@+id/btn_mark_black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:text="Type"
            android:textColor="@color/dn_text_color_black"
            android:textSize="12dp"
            app:layout_constraintEnd_toEndOf="@+id/tvHost"
            app:layout_constraintStart_toStartOf="@+id/tvHost"
            app:layout_constraintTop_toBottomOf="@+id/tvHost"/>

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:text="Host"
            android:textColor="@color/dn_text_color_black"
            android:textSize="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/tvHost"
            app:layout_constraintStart_toStartOf="@+id/tvHost"
            app:layout_constraintTop_toBottomOf="@+id/tvType" />

        <com.coorchice.library.SuperTextView
            android:id="@+id/btn_mark_black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:padding="4dp"
            android:text="+黑名单"
            android:textColor="@color/mdr_white"
            android:textSize="14dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:stv_corner="5dp"
            app:stv_solid="@color/colorPrimary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>